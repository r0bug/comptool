<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1a1a2e"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CompTool Capture"
            android:textSize="22sp"
            android:textColor="#FFe94560"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Captures eBay sold listings while you browse the eBay app."
            android:textColor="#FF888888"
            android:textSize="13sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Not running"
            android:textColor="#FF888888"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/captureCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Comps captured: 0"
            android:textColor="#FF4caf50"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="API Key"
            android:textColor="#FFcccccc"
            android:textSize="12sp"
            android:layout_marginBottom="2dp" />

        <EditText
            android:id="@+id/apiKeyInput"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="ct_your_api_key"
            android:textColor="#FFeeeeee"
            android:textColorHint="#FF555555"
            android:background="#FF16213e"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:textSize="13sp"
            android:singleLine="true"
            android:inputType="text"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/saveKeyBtn"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Save API Key"
            android:textColor="#FFffffff"
            android:backgroundTint="#FFe94560"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/openSettingsBtn"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Enable Accessibility Service"
            android:textColor="#FFffffff"
            android:backgroundTint="#FF0f3460"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Setup:\n\n1. Enter API key, tap Save\n2. Tap Enable Accessibility Service\n3. Find CompTool Capture, toggle ON\n4. Open eBay app, browse sold items\n5. Comps capture automatically"
            android:textColor="#FFaaaaaa"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.5" />

    </LinearLayout>
</ScrollView>
