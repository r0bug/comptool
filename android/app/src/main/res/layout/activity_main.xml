<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#1a1a2e">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CompTool Capture"
        android:textSize="24sp"
        android:textColor="#e94560"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Captures eBay sold listings while you browse the eBay app."
        android:textColor="#888888"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="API Key"
        android:textColor="#cccccc"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/apiKeyInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="ct_your_api_key"
        android:textColor="#eeeeee"
        android:textColorHint="#555555"
        android:background="#16213e"
        android:padding="12dp"
        android:textSize="14sp"
        android:inputType="text"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/saveKeyBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save API Key"
        android:textColor="#ffffff"
        android:background="#e94560"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/openSettingsBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable Accessibility Service"
        android:textColor="#ffffff"
        android:background="#0f3460"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: Not running"
        android:textColor="#888888"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/captureCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Comps captured this session: 0"
        android:textColor="#4caf50"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="How to use:\n\n1. Enter your API key and tap Save\n2. Tap Enable Accessibility Service\n3. Find CompTool Capture and toggle it ON\n4. Open the eBay app and browse sold listings\n5. Comps are captured automatically as you scroll"
        android:textColor="#aaaaaa"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.4" />

</LinearLayout>
