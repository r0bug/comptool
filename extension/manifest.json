{
  "manifest_version": 3,
  "name": "CompTool - eBay Sold Comps",
  "version": "1.5.2",
  "description": "Scrape eBay Terapeak sold comps and save to your CompTool database",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://www.ebay.com/*",
    "https://listflow.robug.com/*",
    "http://localhost:3002/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.ebay.com/sh/research*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.ebay.com/sch/*", "https://www.ebay.com/seller/*", "https://www.ebay.com/usr/*", "https://www.ebay.com/str/*"],
      "js": ["content-sold.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
