{
  "name": "comptool",
  "version": "1.0.0",
  "description": "A tool for pricing items for sale",
  "main": "src/index.js",
  "scripts": {
    "merge": "node src/services/compMerger.js",
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "categorize": "node src/services/categorizer.js",
    "enricher": "node src/services/enricher.js",
    "enricher:start": "pm2 start src/services/enricher.js --name comptool-enricher",
    "enricher:stop": "pm2 stop comptool-enricher",
    "enricher:logs": "pm2 logs comptool-enricher --lines 50",
    "ebay-enricher": "node src/services/ebayEnricher.js",
    "ebay-enricher:start": "pm2 start src/services/ebayEnricher.js --name comptool-ebay-enricher",
    "ebay-enricher:stop": "pm2 stop comptool-ebay-enricher",
    "ebay-enricher:logs": "pm2 logs comptool-ebay-enricher --lines 50",
    "ext:build": "cd extension && zip -r ../public/comptool-extension.zip . -x '.*'"
  },
  "keywords": [],
  "author": "robug",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "nodemon": "^3.1.14",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "prisma": "^6.19.2",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.34.5"
  }
}
